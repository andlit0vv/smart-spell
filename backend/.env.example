# Simple PostgreSQL config (matches backend/db.py)
user=postgres
password=
host=db.your-project-ref.supabase.co
port=5432
dbname=postgres

# Optional: if set, backend will parse missing fields from this URL.
# DATABASE_URL=postgresql://postgres:<YOUR-PASSWORD>@db.your-project-ref.supabase.co:5432/postgres

# Local Telegram simulation. On first GET /api/profile user is auto-created in DB.
LOCAL_TEST_TELEGRAM_ID=1000000001
LOCAL_TEST_USERNAME=local_tester
LOCAL_TEST_FIRST_NAME=Local
