# Preferred DSN (single variable)
DATABASE_URL=postgresql://andrey:<PASSWORD>@localhost:5432/anovadb

# Optional per-field PostgreSQL config (used only when DATABASE_URL is empty)
PGUSER=andrey
PGPASSWORD=<PASSWORD>
PGHOST=localhost
PGPORT=5432
PGDATABASE=anovadb
PGSSLMODE=prefer

# Local Telegram simulation. On first GET /api/profile user is auto-created in DB.

TELEGRAM_BOT_TOKEN=<BOT_TOKEN>
TELEGRAM_AUTH_MODE=strict
# For local/dev server calls without Telegram Mini App headers:
# TELEGRAM_AUTH_MODE=permissive
# DEV_TELEGRAM_USER_ID=1000001
# DEV_TELEGRAM_USERNAME=local_dev
# DEV_TELEGRAM_FIRST_NAME=Local
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=gpt-5-mini
