# Preferred default: Supabase Session Pooler (IPv4-compatible).
# You can paste the exact key-value DSN from Supabase "Connection string -> Session pooler".
# Example format:
# user=postgres.<project-ref> password=<password> host=aws-1-<region>.pooler.supabase.com port=5432 dbname=postgres
DATABASE_POOLER_DSN=

# Optional URL variant for the same pooler, if you prefer URL syntax.
DATABASE_POOLER_URL=

# Optional direct DB connection (fallback/alternative).
DATABASE_URL=
DATABASE_DIRECT_URL=

# Local Telegram simulation. On first GET /api/profile user is auto-created in DB.
LOCAL_TEST_TELEGRAM_ID=1000000001
LOCAL_TEST_USERNAME=local_tester
LOCAL_TEST_FIRST_NAME=Local
